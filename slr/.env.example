# Zotero API Keys — SLR Project
# Create keys at https://www.zotero.org/settings/keys
# Scope each key to this library only; do NOT use your master API key here.

# Read-only key: for searching, listing, and reading items
ZOTERO_API_KEY_READONLY=

# Read-write key: for adding/tagging/updating items (use sparingly)
ZOTERO_API_KEY_READWRITE=

# Library identifiers — get from your Zotero library URL
# e.g. https://www.zotero.org/groups/1234567/your_slr_group
ZOTERO_GROUP_ID=
ZOTERO_USER_ID=          # only needed if using a personal library instead of a group
ZOTERO_LIBRARY_TYPE=group  # "group" (preferred for shared SLR) or "user"

# API base (default; only change for self-hosted Zotero)
ZOTERO_API_BASE_URL=https://api.zotero.org
