# SLR Search Tools — Environment Configuration Template
#
# Copy this file to slr/.env and fill in your values.
# The .env file is gitignored. Never commit real keys.
#
# Run slr/scripts/install-search-tools.sh to set everything up interactively.

# ── Exa ──────────────────────────────────────────────────────────────────────
# Required. Get your key at https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# ── Semantic Scholar ──────────────────────────────────────────────────────────
# Optional. Without a key the MCP server runs unauthenticated (1 req/sec limit).
# Request a key at https://www.semanticscholar.org/product/api
# Leave blank to run unauthenticated; calls must be made sequentially.
SEMANTIC_SCHOLAR_API_KEY=

# ── Zotero ────────────────────────────────────────────────────────────────────
# Create two scoped API keys at https://www.zotero.org/settings/keys
# Scope each key to this library only — do NOT use your master API key.

# Read-only key: searching, listing, and reading items
ZOTERO_API_KEY_READONLY=

# Read-write key: adding tags and updating items (use sparingly — writes are irreversible)
ZOTERO_API_KEY_READWRITE=

# Library identifiers — visible in your Zotero library URL
# e.g. https://www.zotero.org/groups/1234567/your_slr_group
ZOTERO_GROUP_ID=
ZOTERO_USER_ID=           # only needed if using a personal library instead of a group

# "group" (preferred for shared SLR work) or "user" (personal library)
ZOTERO_LIBRARY_TYPE=group

# API base URL — only change this for a self-hosted Zotero instance
ZOTERO_API_BASE_URL=https://api.zotero.org
